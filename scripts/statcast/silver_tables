DDL: Silver Table Schema

/*===========================================================
DDL: Pitch Physics
============================================================*/
DROP TABLE IF EXISTS silver.statcast_pitch_physics_clean;

CREATE TABLE silver.statcast_pitch_physics_clean (
    pitch_id          INT PRIMARY KEY, -- Enforces uniqueness
    pitcher           INT NOT NULL,
    game_date         DATE NOT NULL,
    pitch_type        VARCHAR(10) NOT NULL,
    release_speed     DECIMAL(4,1),    -- Example: 101.5
    release_spin_rate INT,             -- Spins are whole numbers
    pfx_x             DECIMAL(5,2),    -- Precise movement
    pfx_z             DECIMAL(5,2)
);

INSERT INTO silver.statcast_pitch_physics_clean (
    pitch_id, 
    pitcher, 
    game_date, 
    pitch_type, 
    release_speed, 
    release_spin_rate, 
    pfx_x, 
    pfx_z
)
SELECT 
    pitch_id, 
    pitcher, 
    game_date, 
    pitch_type, 
    release_speed, 
    release_spin_rate, 
    pfx_x, 
    pfx_z
FROM silver.statcast_pitch_physics
WHERE release_speed IS NOT NULL 
  AND pitch_type IS NOT NULL;

/*===============================================
DDL: Batted Ball
================================================*/
DROP TABLE IF EXISTS silver.statcast_batted_ball_clean;

CREATE TABLE silver.statcast_batted_ball_clean (
    pitch_id         INT PRIMARY KEY,
    pitcher          INT NOT NULL,
    game_date        DATE NOT NULL,
    launch_speed     DECIMAL(4,1), -- Exit Velocity
    launch_angle     INT,           -- Launch Angle
    hit_distance_sc  INT,           -- Distance in feet
    events           VARCHAR(50)    -- e.g., 'single', 'home_run'
);

INSERT INTO silver.statcast_batted_ball_clean (
    pitch_id, 
    pitcher, 
    game_date, 
    launch_speed, 
    launch_angle, 
    hit_distance_sc, 
    events
)
SELECT 
    pitch_id, 
    pitcher, 
    game_date, 
    launch_speed, 
    launch_angle, 
    hit_distance_sc, 
    events
FROM silver.statcast_batted_ball
WHERE launch_speed IS NOT NULL;

