/*========================================================
DDL: Plate Discipline
=======================================================*/
DROP TABLE IF EXISTS silver.statcast_plate_discipline;

CREATE TABLE silver.statcast_plate_discipline (
    pitch_id       INT PRIMARY KEY, -- The link to all other tables
    pitcher        INT NOT NULL,
    batter         INT NOT NULL,
    plate_x        DECIMAL(5,2),    -- Left/Right position over the plate
    plate_z        DECIMAL(5,2),    -- Height over the plate
    sz_top         DECIMAL(5,2),    -- Top of that specific batter's strike zone
    sz_bot         DECIMAL(5,2),    -- Bottom of that specific batter's strike zone
    zone           INT,             -- Statcast zone number (1-14)
    description    VARCHAR(50)      -- e.g., 'called_strike', 'ball', 'swinging_strike'
);

INSERT INTO silver.statcast_plate_discipline (
pitch_id, 
pitcher, 
batter, 
plate_x, 
plate_z, 
sz_top, 
sz_bot, 
zone, 
description
)

SELECT 
pitch_id, 
pitcher, 
batter, 
plate_x, 
plate_z, 
sz_top, 
sz_bot, 
zone, 
description
FROM bronze.statcast_raw;

/*==========================================================
DDL: Swing Metrics
==========================================================*/

DROP TABLE IF EXISTS silver.statcast_game_context;

CREATE TABLE silver.statcast_game_context (
    pitch_id       INT PRIMARY KEY,
    inning         INT,
    inning_topbot  VARCHAR(3),      -- 'Top' or 'Bot'
    balls          INT,
    strikes        INT,
    outs_when_up   INT,
    on_3b          INT,             -- Usually the Player ID of the runner
    on_2b          INT,
    on_1b          INT,
    fld_score      INT,             -- Fielding team's current score
    bat_score      INT              -- Batting team's current score
);

INSERT INTO silver.statcast_game_context (
pitch_id, 
inning, 
inning_topbot, 
balls, 
strikes, 
outs_when_up, 
on_3b, 
on_2b, 
on_1b, 
fld_score, 
bat_score
)

SELECT 
pitch_id, 
inning, 
inning_topbot, 
balls, 
strikes, 
outs_when_up, 
on_3b, 
on_2b, 
on_1b, 
fld_score, 
bat_score
FROM bronze.statcast_raw;

